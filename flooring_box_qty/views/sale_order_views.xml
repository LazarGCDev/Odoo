<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_flooring_box_qty" model="ir.ui.view">
        <field name="name">product.template.form.flooring.box.qty</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='uom_id']" position="after">
                <field name="sqft_per_box"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_form_view_flooring_box_qty" model="ir.ui.view">
        <field name="name">sale.order.form.flooring.box.qty</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//*[self::list or self::tree]//field[@name='product_uom_qty']" position="before">
                <field name="requested_sqft" optional="show"/>
                <field name="sqft_per_box" optional="show" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
