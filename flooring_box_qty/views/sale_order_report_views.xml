<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document_flooring_box_qty" inherit_id="sale.report_saleorder_document">
        <xpath expr="//th[@name='th_quantity']" position="before">
            <th t-if="doc.order_line.filtered('use_box_sqft_calculation')" name="th_requested_sqft" class="text-end">Requested Sq Ft</th>
            <th t-if="doc.order_line.filtered('use_box_sqft_calculation')" name="th_sqft_per_box" class="text-end">Sq Ft/Box</th>
        </xpath>
        <xpath expr="//td[@name='td_product_quantity']" position="before">
            <td t-if="doc.order_line.filtered('use_box_sqft_calculation')" name="td_requested_sqft" class="text-end">
                <span t-if="line.use_box_sqft_calculation" t-field="line.requested_sqft"/>
            </td>
            <td t-if="doc.order_line.filtered('use_box_sqft_calculation')" name="td_sqft_per_box" class="text-end">
                <span t-if="line.use_box_sqft_calculation" t-field="line.sqft_per_box"/>
            </td>
        </xpath>
        <xpath expr="//td[@name='td_product_quantity']" position="replace">
            <td name="td_product_quantity" class="o_td_quantity text-end">
                <t t-if="line.use_box_sqft_calculation">
                    <span t-field="line.product_uom_qty" class="text-nowrap"/>
                    <span t-field="line.product_uom_id"/>
                    <span t-if="line.box_qty">
                        (<span t-field="line.box_qty"/> boxes)
                    </span>
                </t>
                <t t-else="">
                    <span t-field="line.product_uom_qty" class="text-nowrap"/>
                    <span t-field="line.product_uom_id"/>
                    <span t-if="line.product_uom_id != line.product_id.uom_id" class="text-muted small">
                        <t t-set="quantity_in_product_uom" t-value="line.product_uom_id._compute_quantity(line.product_uom_qty, line.product_id.uom_id)"/>
                        <br/><span t-esc="quantity_in_product_uom" t-options="{'widget': 'float', 'decimal_precision': 'Product Unit'}"/> <span t-field="line.product_id.uom_id"/>
                    </span>
                </t>
            </td>
        </xpath>
    </template>

    <template id="sale_order_portal_content_flooring_box_qty" inherit_id="sale.sale_order_portal_content">
        <xpath expr="//th[@id='product_qty_header']" position="before">
            <th t-if="sale_order.order_line.filtered('use_box_sqft_calculation')" class="text-end">Requested Sq Ft</th>
            <th t-if="sale_order.order_line.filtered('use_box_sqft_calculation')" class="text-end">Sq Ft/Box</th>
        </xpath>
        <xpath expr="//td[@name='td_product_quantity']" position="before">
            <td t-if="sale_order.order_line.filtered('use_box_sqft_calculation')" class="text-end">
                <span t-if="line.use_box_sqft_calculation" t-field="line.requested_sqft"/>
            </td>
            <td t-if="sale_order.order_line.filtered('use_box_sqft_calculation')" class="text-end">
                <span t-if="line.use_box_sqft_calculation" t-field="line.sqft_per_box"/>
            </td>
        </xpath>
        <xpath expr="//td[@name='td_product_quantity']" position="replace">
            <td name="td_product_quantity" class="text-end">
                <t t-if="line.use_box_sqft_calculation">
                    <div id="quote_qty">
                        <span t-field="line.product_uom_qty"/>
                        <span t-field="line.product_uom_id"/>
                        <span t-if="line.box_qty">
                            (<span t-field="line.box_qty"/> boxes)
                        </span>
                    </div>
                </t>
                <t t-else="">
                    <div id="quote_qty">
                        <span t-field="line.product_uom_qty"/>
                        <span t-field="line.product_uom_id"/>
                    </div>
                </t>
            </td>
        </xpath>
    </template>
</odoo>
