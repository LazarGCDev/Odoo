<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_picking_form_view_flooring_box_qty" model="ir.ui.view">
        <field name="name">stock.picking.form.flooring.box.qty</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_ids']//list//field[@name='quantity']" position="before">
                <field name="use_box_sqft_calculation" column_invisible="1"/>
                <field name="sqft_per_box" optional="show" readonly="1" invisible="not use_box_sqft_calculation"/>
                <field name="received_box_qty" optional="show" invisible="not use_box_sqft_calculation"/>
            </xpath>
        </field>
    </record>
</odoo>
